# Copier ce fichier en .env et remplir les valeurs

# ── Anthropic ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ──────────────────────────────────────
# URL du projet Supabase (visible dans Settings > API)
SUPABASE_URL=https://zbzicommpdsvkesqzyvb.supabase.co

# Clé service (Settings > API > service_role) — JAMAIS exposée côté client
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxx

# URL de connexion directe à la base PostgreSQL (Settings > Database > Connection string)
# Format : postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.zbzicommpdsvkesqzyvb.supabase.co:5432/postgres

# ── Serveur ───────────────────────────────────────
PORT=3004

# ── CORS — origines autorisées ────────────────────
