          "parameters": [
            { "name": "x-api-key", "value": "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" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 600,\n  \"system\": \"Tu es l'expert marketing immobilier de Visit & Smile a Orleans (Alison Mendes, auto-entrepreneuse). Tu rediges des posts Instagram accrocheurs pour des biens immobiliers. Format : hook punchy sur la 1ere ligne, 2-3 phrases descriptives avec emojis, call-to-action (CTA), puis 8-12 hashtags pertinents (immobilier, Orleans, mots-cles du bien). Ton chaleureux et professionnel. Toujours en francais.\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Redige un post Instagram pour cette photo : {{ $json.description }}\"\n    }\n  ]\n}",
        "options": {}
      },
      "name": "Claude Genere Caption",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [920, 300],
      "id": "claude-caption"
    },
    {
      "parameters": {
        "jsCode": "// Combiner les infos du media avec la caption generee\nconst media = $('Extract Media').first().json;\nconst claude = items[0].json;\nconst caption = claude.content && claude.content[0] ? claude.content[0].text : 'Nouveau bien disponible !';\n\n// Scheduled_at = dans 1h pour laisser Alison approuver\nconst scheduledAt = new Date(Date.now() + 60 * 60 * 1000).toISOString();\n\nreturn [{\n  json: {\n    user_id: media.user_id,\n    media_id: media.media_id,\n    public_url: media.public_url,\n    caption: caption,\n    scheduled_at: scheduledAt,\n    used_count: (media.used_count || 0) + 1\n  }\n}];"
      },
      "name": "Prepare Post",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1160, 300],
      "id": "prepare-post"
