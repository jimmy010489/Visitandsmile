      "parameters": {
        "jsCode": "// Si aucune image, arreter le workflow\nif (!items[0].json || !items[0].json.length) {\n  return [];\n}\nconst media = items[0].json[0];\nreturn [{\n  json: {\n    media_id: media.id,\n    user_id: media.user_id,\n    public_url: media.public_url,\n    description: media.description || media.file_name || 'Bien immobilier',\n    used_count: media.used_count || 0\n  }\n}];"
      },
      "name": "Extract Media",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300],
      "id": "extract-media"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
