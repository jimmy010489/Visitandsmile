            {
              "role": "user",
              "content": "Génère un post pour {{ $json.platform }} avec le ton '{{ $json.tone }}' pour l'audience '{{ $json.target_audience }}'. Format préféré: {{ $json.preferred_format }}. Biens récents disponibles: {{ JSON.stringify($node['Get Recent Properties'].json) }}. Retourne uniquement le JSON."
