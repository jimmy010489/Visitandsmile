    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nlet content;\ntry {\n  const text = response.content[0].text;\n  content = JSON.parse(text);\n} catch(e) {\n  content = {\n    platform: 'instagram',\n    content_text: response.content[0].text,\n    hashtags: ['#immobilier', '#orleans', '#visitandsmile'],\n    format_type: 'post'\n  };\n}\n\n// Programmer pour le prochain créneau optimal\nconst now = new Date();\nconst scheduled = new Date(now);\nscheduled.setHours(12, 30, 0, 0);\nif (scheduled <= now) {\n  scheduled.setDate(scheduled.getDate() + 1);\n}\n\nreturn [{\n  json: {\n    ...content,\n    user_id: fa832096-ef0a-4f6e-8136-7de3e5b00a4d,\n    scheduled_at: scheduled.toISOString(),\n    status: 'scheduled'\n  }\n}];"
      },
